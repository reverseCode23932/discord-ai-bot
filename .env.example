# Official bot token — NOT your personal account token
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here
BOT_PREFIX=!

# --- LLM (chat replies) — pick ONE provider ---
# Local, free (recommended if OpenAI quota is empty):
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
# LLM_BASE_URL=http://127.0.0.1:11434/v1

# Groq free tier (https://console.groq.com):
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-8b-instant

# OpenAI (paid):
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# LM Studio / other OpenAI-compatible server:
# LLM_PROVIDER=custom
# LLM_BASE_URL=http://127.0.0.1:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name

# Defaults for new users
DEFAULT_LANGUAGE=ru
DEFAULT_SYNTHESIZER=edge
DEFAULT_EDGE_VOICE=ru-RU-DmitryNeural
EDGE_TTS_RATE=-10%
EDGE_TTS_VOLUME=+12%
EDGE_TTS_PITCH=+0Hz

# Logging (files go to data/logs/bot.log)
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_MAX_BYTES=5242880

# Voice listen (/listen) — optional wake word(s), comma-separated; leave empty for any speech
BOT_UI_LANGUAGE=en
VOICE_WAKE_WORDS=
VOICE_REPLY_TTS=true
# Post heard+reply in text during /listen (auto-deletes = whisper style)
VOICE_REPLY_TEXT=false
CHAT_WHISPER_DELETE_AFTER=90
CHAT_EPHEMERAL=true
STT_ENGINE=local
# small = good Russian accuracy; medium = best (needs ~5GB RAM)
WHISPER_LOCAL_MODEL=medium
# auto | cuda | cpu — RTX 4060: cuda + float16 after install-gpu-stt.ps1
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=
WHISPER_BEAM_SIZE=8
WHISPER_VAD_FILTER=true
VOICE_UTTERANCE_COOLDOWN=3
VOICE_ERROR_COOLDOWN=60
LLM_TIMEOUT_SECONDS=180
MIN_SPEECH_BYTES=76800
